# Banco de dados PostgreSQL
# Recomendação: Neon (https://neon.tech) — grátis, 3 cliques pra criar.
# Formato: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=

# Cookie de sessão (HMAC). Gere com: openssl rand -hex 32
SESSION_SECRET=

# Anthropic — pra importação de fatura com IA
ANTHROPIC_API_KEY=
